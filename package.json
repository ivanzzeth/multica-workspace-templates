{
  "name": "multica-workspace-templates",
  "version": "1.0.0",
  "description": "Multica workspace template manager — import/export agent teams, projects, labels, and autopilots",
  "type": "module",
  "bin": {
    "multica-templates": "./bin/cli.js"
  },
  "files": [
    "bin/",
    "dist/",
    "src/",
    "templates/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "tsx src/main.ts --dev",
    "dev:electron": "tsx src/main.ts --dev --electron",
    "start": "tsx src/main.ts",
    "start:electron": "tsx src/main.ts --electron",
    "build": "vite build",
    "prepublishOnly": "npm run build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:unit": "vitest run --dir tests/unit",
    "test:integration": "vitest run --dir tests/integration"
  },
  "dependencies": {
    "express": "^5.1.0",
    "open": "^10.2.0",
    "semver": "^7.8.1",
    "tsx": "^4.19.3",
    "yaml": "^2.7.1"
  },
  "devDependencies": {
    "@types/express": "^5.0.1",
    "@types/node": "^22.14.1",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@types/semver": "^7.7.1",
    "@vitejs/plugin-react": "^4.4.1",
    "electron": "^35.1.2",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "typescript": "^5.8.3",
    "vite": "^6.3.2",
    "vitest": "^4.1.7"
  }
}
